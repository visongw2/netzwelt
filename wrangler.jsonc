{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "netzwelt",
  "compatibility_date": "2026-05-09",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "exclude": [
      ".git/**",
      ".gitignore",
      "node_modules/**",
      "*.py",
      "*.bat",
      "*.ps1",
      "backup_restore/**",
      ".workbuddy/**",
      ".codebuddy/**"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
